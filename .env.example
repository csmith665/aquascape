# --- Application / proxy ---
# Domain Traefik serves this app on. Set to a real domain (A record -> this server)
# for automatic Let's Encrypt TLS via the shared proxy at /home/cms/proxy.
DOMAIN=aquascape.local

# --- Database credentials ---
# Generate a strong password before first start, e.g.:
#   openssl rand -hex 18
# The same POSTGRES_PASSWORD is used by the db service and the app's DATABASE_URL.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=REPLACE_WITH_OUTPUT_OF_openssl_rand_hex_18
POSTGRES_DB=aquascape

# Used by local dev and one-off prisma commands. Keep POSTGRES_PASSWORD in sync.
# Compose is on the host network, so use localhost + the same password.
DATABASE_URL=postgresql://postgres:REPLACE_WITH_OUTPUT_OF_openssl_rand_hex_18@localhost:5432/aquascape
NODE_ENV=production
