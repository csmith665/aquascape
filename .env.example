# Domain Caddy serves on. Required for automatic Let's Encrypt TLS certs.
# Point this domain's A record at your server's public IP before starting.
# Defaults to "localhost" (self-signed cert) if unset.
DOMAIN=localhost

# Used by local dev and one-off prisma commands. Keep in sync with docker-compose.yml.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/aquascape"
NODE_ENV="production"
