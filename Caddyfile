{
	# Use the domain from the environment; default to localhost for local dev.
	# For a real domain, Caddy obtains and renews a Let's Encrypt certificate
	# automatically on first start (requires ports 80 and 443 to be reachable
	# from the internet, and the domain's A record to point at this server).
	email {$DOMAIN:localhost}
}

{$DOMAIN:localhost} {
	encode zstd gzip

	header {
		# Strict-Transport-Security: enforce HTTPS for 1 year once a real cert is in use.
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		# Security headers (Next.js also sets these, but set them here so the
		# very first response — including the TLS challenge — is covered).
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
		# Remove the Caddy Server header to avoid leaking version info.
		-Server
	}

	reverse_proxy app:3000 {
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-For {remote_host}
		header_up X-Forwarded-Proto {scheme}
	}
}
